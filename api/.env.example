# Copy this to .env for local dev, or set these in Railway's dashboard for production

# Database — Supabase connection string (get from Supabase → Project Settings → Database → URI)
# Use the "Transaction pooler" URI and replace [YOUR-PASSWORD]
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# JWT — generate a strong random string (e.g. openssl rand -hex 32)
SECRET_KEY=your-secret-key-here

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000,http://localhost:3001
